Frames are used when a webpage embeds another HTML document inside it.

Different types of Frame handling:-
┌─────────────────────────────────────┬───────────────────────────────────────────────────────┐
//  │ Topic                               │ Purpose                                       │
//  ├─────────────────────────────────────┼───────────────────────────────────────────────────────┤
//  │ page.frame()                         │ Get frame by name/url matcher.                │
//  │ page.frameLocator()                  │ Stable way to target elements inside frame.   │
//  │ frame.locator()                      │ Locate and act inside a resolved frame.       │
//  │ frame.name() / frame.url()           │ Inspect frame identity for debugging.          │
//  │ page.frames()                        │ List all frames currently attached.            │
//  │ frame.waitForSelector()              │ Wait for content inside a slow-loading frame.  │
//  │ nested frameLocator() chaining       │ Handle frame inside frame (nested frames).     │
//  │ frame.contentFrame()                 │ Convert iframe element locator to Frame object.│
//  └─────────────────────────────────────┴───────────────────────────────────────────────────────┘

// NOTE:
// 1) Prefer frameLocator() for reliability and readability.
// 2) For dynamic/late frames, wait for the frame or target element before action.
// 3) Use Promise.all() if frame loads after a click/navigation to avoid race conditions.


// @ts-check
import { test, expect } from '@playwright/test';

// =============================================================================
//  COMPLETE GUIDE TO PLAYWRIGHT FRAMES
// =============================================================================
//
//  Frames (iframes) are embedded browsing contexts with their own DOM.
//  You cannot directly use page.locator() for elements inside a frame unless
//  you first switch scope using frameLocator() or frame APIs.
//
//  STRUCTURE OF THIS GUIDE
//  ─────────────────────────────────────────────────────────────────────────
//  PART 1 - BASIC FRAME ACCESS
//    1.1 frameLocator() by CSS selector
//    1.2 page.frame() by name/url
//    1.3 page.frames() to inspect available frames
//
//  PART 2 - WORKING INSIDE FRAMES
//    2.1 frame.locator() actions and assertions
//    2.2 frame.waitForSelector() for delayed frame content
//    2.3 iframe element -> contentFrame()
//
//  PART 3 - NESTED FRAMES
//    3.1 frameLocator chaining for parent -> child frame
// =============================================================================


// ─────────────────────────────────────────────────────────────────────────────
//  PART 1 - BASIC FRAME ACCESS
// ─────────────────────────────────────────────────────────────────────────────

// ─── 1.1 frameLocator() by CSS selector ─────────────────────────────────────
//  DEFINITION:
//    frameLocator() scopes actions to a target iframe without manually
//    resolving Frame objects.
// ─────────────────────────────────────────────────────────────────────────────
test('1.1 frameLocator() - fill input inside iframe', async ({ page }) => {
	await page.goto('https://the-internet.herokuapp.com/iframe');

	const editorFrame = page.frameLocator('#mce_0_ifr');
	const body = editorFrame.locator('body#tinymce');

	await body.fill('Playwright frameLocator demo');
	await expect(body).toContainText('Playwright frameLocator demo');
});


// ─── 1.2 page.frame() by name/url ───────────────────────────────────────────
//  DEFINITION:
//    page.frame() returns a Frame object using a frame name or URL matcher.
// ─────────────────────────────────────────────────────────────────────────────
test('1.2 page.frame() - resolve frame by url and assert content', async ({ page }) => {
	await page.goto('https://the-internet.herokuapp.com/iframe');

	const tinyMceFrame = page.frame({ url: /tinymce/ });
	expect(tinyMceFrame).toBeTruthy();

	const body = tinyMceFrame.locator('body#tinymce');
	await expect(body).toBeVisible();
});


// ─── 1.3 page.frames() inspect all frames ───────────────────────────────────
//  DEFINITION:
//    page.frames() lists main frame + child frames. Useful for debugging.
// ─────────────────────────────────────────────────────────────────────────────
test('1.3 page.frames() - validate iframe is attached', async ({ page }) => {
	await page.goto('https://the-internet.herokuapp.com/iframe');

	const frames = page.frames();
	const frameUrls = frames.map(frame => frame.url());

	expect(frameUrls.some(url => url.includes('tinymce'))).toBeTruthy();
});


// ─────────────────────────────────────────────────────────────────────────────
//  PART 2 - WORKING INSIDE FRAMES
// ─────────────────────────────────────────────────────────────────────────────

// ─── 2.1 frame.locator() actions and assertions ─────────────────────────────
//  DEFINITION:
//    Once you have a Frame object, use frame.locator() for all operations.
// ─────────────────────────────────────────────────────────────────────────────
test('2.1 frame.locator() - clear and type content in editor frame', async ({ page }) => {
	await page.goto('https://the-internet.herokuapp.com/iframe');

	const frame = page.frame({ url: /tinymce/ });
	expect(frame).toBeTruthy();

	const editorBody = frame.locator('body#tinymce');
	await editorBody.fill('');
	await editorBody.type('Typing inside iframe using frame.locator()');

	await expect(editorBody).toContainText('Typing inside iframe using frame.locator()');
});


// ─── 2.2 frame.waitForSelector() for delayed content ───────────────────────
//  DEFINITION:
//    Wait for a selector inside frame when content appears asynchronously.
// ─────────────────────────────────────────────────────────────────────────────
test('2.2 frame.waitForSelector() - wait for editor body before action', async ({ page }) => {
	await page.goto('https://the-internet.herokuapp.com/iframe');

	const frame = page.frame({ url: /tinymce/ });
	expect(frame).toBeTruthy();

	await frame.waitForSelector('body#tinymce');
	await expect(frame.locator('body#tinymce')).toBeVisible();
});


// ─── 2.3 iframe element -> contentFrame() ──────────────────────────────────
//  DEFINITION:
//    Start from iframe element locator, then convert to Frame using
//    contentFrame() for low-level frame operations.
// ─────────────────────────────────────────────────────────────────────────────
test('2.3 contentFrame() - resolve frame from iframe element', async ({ page }) => {
	await page.goto('https://the-internet.herokuapp.com/iframe');

	const iframeElement = page.locator('#mce_0_ifr');
	const frame = await iframeElement.contentFrame();
	expect(frame).toBeTruthy();

	await expect(frame.locator('body#tinymce')).toBeVisible();
});


// ─────────────────────────────────────────────────────────────────────────────
//  PART 3 - NESTED FRAMES
// ─────────────────────────────────────────────────────────────────────────────

// ─── 3.1 Nested frameLocator chaining ───────────────────────────────────────
//  DEFINITION:
//    For frame inside another frame, chain frameLocator() calls.
// ─────────────────────────────────────────────────────────────────────────────
test('3.1 Nested frames - access frame inside frame and assert text', async ({ page }) => {
	await page.goto('https://the-internet.herokuapp.com/nested_frames');

	const middleFrameContent = page
		.frameLocator('frame[name="frame-top"]')
		.frameLocator('frame[name="frame-middle"]')
		.locator('#content');

	await expect(middleFrameContent).toHaveText('MIDDLE');
});
