// ─────────────────────────────────────────────────────────────────────────────
//  PART 1 - Browser, BrowserContext, and Page
// ─────────────────────────────────────────────────────────────────────────────

// ─── 1.1 Concept and lifecycle ──────────────────────────────────────────────
//  Browser:
//    Real browser process (Chromium/Firefox/WebKit).
//
//  BrowserContext:
//    Isolated incognito-like environment inside one browser.
//    Each context has separate cookies, localStorage, sessionStorage.
//
//  Page:
//    A tab inside a BrowserContext.
//
//  Typical runtime flow:
//    Browser -> Context -> Page
//
//  In Playwright Test runner, you usually receive `page` fixture directly,
//  and Playwright manages browser/context lifecycle for you.


// ─── 1.2 Practical isolation demo with two contexts ─────────────────────────
test('1.2 BrowserContext isolation - cookies are isolated between contexts', async ({ browser }) => {
	const contextA = await browser.newContext();
	const contextB = await browser.newContext();

	const pageA = await contextA.newPage();
	const pageB = await contextB.newPage();

	await pageA.goto('https://example.com');
	await pageB.goto('https://example.com');

	await contextA.addCookies([
		{ name: 'session', value: 'A', domain: 'example.com', path: '/' }
	]);
	await contextB.addCookies([
		{ name: 'session', value: 'B', domain: 'example.com', path: '/' }
	]);

	const cookiesA = await contextA.cookies();
	const cookiesB = await contextB.cookies();

	expect(cookiesA.find(c => c.name === 'session')?.value).toBe('A');
	expect(cookiesB.find(c => c.name === 'session')?.value).toBe('B');

	await contextA.close();
	await contextB.close();
});


