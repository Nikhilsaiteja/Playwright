// ─────────────────────────────────────────────────────────────────────────────
//  PART 5 - textContent vs innerText vs innerHTML
// ─────────────────────────────────────────────────────────────────────────────

// ─── 5.1 Behavior differences ───────────────────────────────────────────────
//  textContent:
//    - Returns raw text from DOM nodes.
//    - Includes hidden text.
//    - Does not trigger layout calculations.
//
//  innerText:
//    - Returns rendered, user-visible text.
//    - Ignores hidden elements.
//    - Reflects CSS visibility and line breaks.
//
//  innerHTML:
//    - Returns HTML markup inside element.
//    - Useful for structure checks, not pure text checks.


// ─── 5.2 Runnable comparison example ────────────────────────────────────────
test('5.2 textContent vs innerText vs innerHTML - practical example', async ({ page }) => {
	await page.setContent(`
		<div id="box">
		  Hello <span style="display:none">Hidden</span>
		  <b>World</b>
		</div>
	`);

	const box = page.locator('#box');

	const rawText = await box.textContent();
	const visibleText = await box.innerText();
	const markup = await box.innerHTML();

	// textContent includes hidden text, innerText only visible text.
	expect(rawText).toContain('Hidden');
	expect(visibleText).toContain('Hello');
	expect(visibleText).toContain('World');
	expect(visibleText).not.toContain('Hidden');

	// innerHTML preserves tags inside the selected element.
	expect(markup).toContain('<b>World</b>');
});